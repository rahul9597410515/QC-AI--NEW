PORT=3001
NODE_ENV=development

# SQLite database (no setup required)
DATABASE_URL="file:./qc-ai.db"

# JWT Secret — change this in production!
JWT_SECRET=qc-ai-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# AI Analysis mode: "mock" | "openai" | "gemini"
AI_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=
